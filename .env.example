DATABASE_URL="postgresql://neondb_owner:your_password@ep-your-neon-host.us-east-2.aws.neon.tech/neondb?sslmode=require"
APP_HOST="0.0.0.0"
APP_PORT="8787"
APP_CORS_ORIGIN="*"
S3_REGION="ap-southeast-1"
S3_BUCKET_NAME="your-bucket-name"
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"
S3_UPLOAD_KEY_PREFIX="products"
# Optional CDN or custom domain for uploaded file URLs.
# Example: https://cdn.example.com
S3_PUBLIC_BASE_URL=""
# Leave empty when frontend and API share the same domain (e.g. Vercel `/api/*` functions).
# Set this to a full URL when using a separate backend host.
# Example: https://api.example.com
VITE_API_BASE_URL=""

# Welcome email (sent after successful sign-up)
WELCOME_EMAIL_ENABLED="true"
WELCOME_EMAIL_SMTP_HOST="smtp.gmail.com"
WELCOME_EMAIL_SMTP_PORT="465"
WELCOME_EMAIL_FROM="nnminh.sam@gmail.com"
WELCOME_EMAIL_USER="nnminh.sam@gmail.com"
# Gmail App Password (not your normal Gmail password)
WELCOME_EMAIL_PASS=""
# CTA destination shown in welcome email button
WELCOME_EMAIL_CTA_URL="http://localhost:5173"
